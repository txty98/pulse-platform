{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@pulse/design-system": ["packages/design-system/src/index.ts"],
      "@pulse/supabase": ["packages/supabase/src/index.ts"],
      "@pulse/ui": ["packages/ui/src/index.ts"]
    }
  }
}
